rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default: deny everything. Every rule below is an explicit exception.
    match /{document=**} {
      allow read, write: if false;
    }

    // Products & categories — public read; all writes go through Admin SDK server-side.
    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    // Orders — authenticated user can read only their own; no client-side writes.
    match /orders/{orderId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if false;
    }

    // User profiles — each user can read and write only their own document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Reviews — authenticated users can read all; can create/update only their own.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
  }
}
